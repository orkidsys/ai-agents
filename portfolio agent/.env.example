# OpenAI API Key (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# CoinGecko API Key (Optional but recommended)
# Free tier available at: https://www.coingecko.com/en/api
# Helps avoid rate limits
COINGECKO_API_KEY=your_coingecko_api_key_here

# Alchemy API Key (Optional, for EVM wallet data)
# Get your API key from: https://www.alchemy.com/
# Required for full EVM wallet balance functionality
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Solana RPC Endpoint (Optional, for Solana wallet data)
# You can use public endpoints or get a dedicated one from providers like:
# - QuickNode: https://www.quicknode.com/
# - Helius: https://www.helius.dev/
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

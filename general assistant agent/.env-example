# Which LLM to use: openai | anthropic | google | gemini | vertex
GENERAL_AGENT_PROVIDER=openai

# Optional default model for all providers (overrides built-in defaults if set)
# GENERAL_AGENT_MODEL=gpt-4o-mini

# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Google Gemini (Generative Language API) ---
GOOGLE_API_KEY=
# or
# GEMINI_API_KEY=

# --- Google Vertex AI ---
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GCP_PROJECT=
# VERTEX_PROJECT=
# VERTEX_LOCATION=

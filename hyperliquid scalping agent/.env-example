# OpenAI API Key for the AI Agent
OPENAI_API_KEY=your_openai_api_key_here

# Hyperliquid Configuration
# Your wallet's private key (64-character hex with 0x prefix)
HYPERLIQUID_PRIVATE_KEY=0x_your_private_key_here

# Your wallet's public address
HYPERLIQUID_ACCOUNT_ADDRESS=0x_your_account_address_here

# Set to "mainnet" for real trading, "testnet" for paper trading
HYPERLIQUID_NETWORK=testnet

# Trading Parameters
# Maximum position size in USD
MAX_POSITION_SIZE_USD=1000

# Default leverage (1-50x)
DEFAULT_LEVERAGE=5

# Risk per trade as percentage of account (e.g., 0.01 = 1%)
RISK_PER_TRADE=0.01

# Take profit percentage (e.g., 0.005 = 0.5%)
TAKE_PROFIT_PCT=0.005

# Stop loss percentage (e.g., 0.003 = 0.3%)
STOP_LOSS_PCT=0.003

# Maximum number of trades per hour
MAX_TRADES_PER_HOUR=10

# Maximum daily drawdown before trading is paused (e.g., 0.05 = 5%)
MAX_DAILY_DRAWDOWN_PCT=0.05

# Trailing stop activation: profit % before trailing activates (e.g., 0.003 = 0.3%)
TRAILING_STOP_ACTIVATION_PCT=0.003

# Trailing stop distance: how far the stop trails from peak (e.g., 0.002 = 0.2%)
TRAILING_STOP_DISTANCE_PCT=0.002
